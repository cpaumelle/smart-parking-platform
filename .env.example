# Smart Parking Platform - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================================================
# DOMAIN & SSL
# ============================================================================
DOMAIN=verdegris.eu
TLS_EMAIL=admin@verdegris.eu

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_DB=parking_platform
POSTGRES_USER=parking_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ============================================================================
# CHIRPSTACK CONFIGURATION
# ============================================================================
# Generate API token from ChirpStack UI: https://chirpstack.${DOMAIN}
# User → API Keys → Add API Key (with Admin permissions)
CHIRPSTACK_API_TOKEN=CHANGE_ME_YOUR_CHIRPSTACK_API_TOKEN
CHIRPSTACK_APP_ID=default-app-id

# ============================================================================
# SMTP CONFIGURATION (for contact form)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=CHANGE_ME_YOUR_SMTP_PASSWORD

# ============================================================================
# INTERNAL SERVICE URLs (Usually no need to change)
# ============================================================================
# These are set in docker-compose.yml with proper defaults
# Only override if you have custom deployment requirements

# TRANSFORM_URL=http://parking-transform:9000/process-uplink/uplink
# PARKING_DISPLAY_SERVICE_URL=http://parking-display:8100
# DOWNLINK_SERVICE_URL=http://parking-downlink:8000
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@parking-postgres:5432/${POSTGRES_DB}
# CHIRPSTACK_API_URL=parking-chirpstack:8080

# ============================================================================
# NOTES
# ============================================================================
# - Never commit .env file to version control
# - Set file permissions: chmod 600 .env
# - Rotate passwords and API tokens regularly
# - For production, use strong passwords (minimum 32 characters)
